            "trace": true,
            "skipFiles": ["socket.io.js"]
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "vis runtime",
            "url": "http://127.0.0.1:8082/vis/index.html#main",
            "trace": true,
            "skipFiles": ["socket.io.js"]
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "vis2 Launch Edit",
