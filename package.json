{
  "name": "iobroker.vis-mapwidgets",
  "version": "0.1.1",
  "description": "mapwidgets",
  "main": "",
  "author": {
    "name": "oweitman",
    "email": "oweitman@gmx.de"
  },
  "homepage": "https://github.com/oweitman/ioBroker.vis-mapwidgets",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "mapwidgets",
    "leaflet",
    "map"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/oweitman/ioBroker.vis-mapwidgets.git"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {},
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@alcalzone/release-script-plugin-manual-review": "^5.2.0",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^22.13.14",
    "ajv": "^8.20.0",
    "typescript": "~6.0.3"
  },
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|eslint.config.mjs|prettier.config.mjs).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "lib/",
    "widgets/mapwidgets/dist/**",
    "widgets/*.html",
    "www/",
    "io-package.json",
    "LICENSE",
    "main.js"
  ],
  "scripts": {
    "test": "node node_modules/mocha/bin/mocha --exit",
    "test:package": "node node_modules/mocha/bin/mocha --exit",
    "test:integration": "node node_modules/mocha/bin/mocha --exit",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint .",
    "lint:debug": "eslint . --debug",
    "repochecker": "npx @iobroker/repochecker https://github.com/oweitman/ioBroker.vis-mapwidgets --local --noinfo",
    "translate": "translate-adapter",
    "translate-widgets": "node ./bin/translate.js --source widgets/mapwidgets/myi18n/en.json --format single",
    "translate-widgets-notranslate": "node ./bin/translate.js --source widgets/mapwidgets/myi18n/en.json --format single --notranslate",
    "build": "npm run build:widgets",
    "build:widgets": "npm ci --prefix widgets && npm run build --prefix widgets",
    "install:all": "npm ci && npm ci --prefix widgets",
    "release": "release-script --all",
    "upload": "NPM_PACK=$(npm pack) && iob url \"$(pwd)/$NPM_PACK\" --debug && rm \"$NPM_PACK\""
  },
  "bugs": {
    "url": "https://github.com/oweitman/ioBroker.vis-mapwidgets/issues"
  },
  "readmeFilename": "README.md"
}
